{
  "manifest_version": 3,
  "name": "Bookmarks Cleaner",
  "version": "1.0.0",
  "description": "Review your bookmarks one by one in a side panel and keep or reject each one.",
  "permissions": ["bookmarks", "sidePanel", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Bookmarks Cleaner"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
